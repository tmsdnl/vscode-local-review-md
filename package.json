{
  "name": "local-review-md",
  "displayName": "Local Review to Markdown",
  "description": "Annotate code with inline review notes, organize them into named groups, and export a saved Markdown file — ready to use as context in any AI-assisted code review.",
  "version": "0.1.0",
  "publisher": "tmsdnl",
  "packageManager": "pnpm@10.33.0",
  "license": "MIT",
  "icon": "resources/marketplace-icon.png",
  "galleryBanner": {
    "color": "#0B5FFF",
    "theme": "dark"
  },
  "pricing": "Free",
  "homepage": "https://github.com/tmsdnl/vscode-local-review-md#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/tmsdnl/vscode-local-review-md.git"
  },
  "bugs": {
    "url": "https://github.com/tmsdnl/vscode-local-review-md/issues"
  },
  "keywords": [
    "code review",
    "AI context",
    "inline comments",
    "markdown export",
    "code annotation"
  ],
  "engines": {
    "vscode": "^1.100.0"
  },
  "extensionKind": [
    "workspace"
  ],
  "capabilities": {
    "virtualWorkspaces": false,
    "untrustedWorkspaces": {
      "supported": "limited",
      "description": "Git metadata capture is disabled in untrusted workspaces. Local review notes and Markdown export remain available for file-backed workspaces."
    }
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onView:codeReviewExplorer",
    "onCommand:codeReview.startSession",
    "onCommand:codeReview.addComment",
    "onCommand:codeReview.createComment",
    "onCommand:codeReview.editComment",
    "onCommand:codeReview.saveComment",
    "onCommand:codeReview.cancelComment",
    "onCommand:codeReview.exportMarkdown",
    "onCommand:codeReview.resolveItem",
    "onCommand:codeReview.dismissItem",
    "onCommand:codeReview.reopenItem",
    "onCommand:codeReview.deleteItem",
    "onCommand:codeReview.editItem",
    "onCommand:codeReview.copyItem",
    "onCommand:codeReview.resolveGroup",
    "onCommand:codeReview.deleteGroup"
  ],
  "main": "./dist/src/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "codeReview.startSession",
        "title": "New Local Review",
        "category": "Local Review",
        "icon": "$(add)"
      },
      {
        "command": "codeReview.addComment",
        "title": "Add Review Note",
        "category": "Local Review"
      },
      {
        "command": "codeReview.createComment",
        "title": "Create",
        "category": "Local Review"
      },
      {
        "command": "codeReview.editComment",
        "title": "Edit Comment",
        "category": "Local Review",
        "icon": "$(edit)"
      },
      {
        "command": "codeReview.saveComment",
        "title": "Save",
        "category": "Local Review"
      },
      {
        "command": "codeReview.cancelComment",
        "title": "Cancel",
        "category": "Local Review"
      },
      {
        "command": "codeReview.exportMarkdown",
        "title": "Export Markdown",
        "category": "Local Review",
        "icon": "$(export)"
      },
      {
        "command": "codeReview.openItem",
        "title": "Open",
        "category": "Local Review",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "codeReview.resolveItem",
        "title": "Resolve Note",
        "category": "Local Review",
        "icon": "$(check)"
      },
      {
        "command": "codeReview.dismissItem",
        "title": "Dismiss Note",
        "category": "Local Review",
        "icon": "$(circle-slash)"
      },
      {
        "command": "codeReview.reopenItem",
        "title": "Reopen Note",
        "category": "Local Review",
        "icon": "$(refresh)"
      },
      {
        "command": "codeReview.deleteItem",
        "title": "Delete Note",
        "category": "Local Review",
        "icon": "$(trash)"
      },
      {
        "command": "codeReview.editItem",
        "title": "Edit Note",
        "category": "Local Review",
        "icon": "$(edit)"
      },
      {
        "command": "codeReview.copyItem",
        "title": "Copy Note",
        "category": "Local Review",
        "icon": "$(copy)"
      },
      {
        "command": "codeReview.resolveGroup",
        "title": "Resolve Local Review",
        "category": "Local Review",
        "icon": "$(check-all)"
      },
      {
        "command": "codeReview.deleteGroup",
        "title": "Delete Local Review",
        "category": "Local Review",
        "icon": "$(trash)"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "codeReview.editItem",
          "when": "false"
        },
        {
          "command": "codeReview.copyItem",
          "when": "false"
        },
        {
          "command": "codeReview.createComment",
          "when": "false"
        },
        {
          "command": "codeReview.openItem",
          "when": "false"
        },
        {
          "command": "codeReview.editComment",
          "when": "false"
        },
        {
          "command": "codeReview.saveComment",
          "when": "false"
        },
        {
          "command": "codeReview.cancelComment",
          "when": "false"
        },
        {
          "command": "codeReview.resolveGroup",
          "when": "false"
        },
        {
          "command": "codeReview.deleteGroup",
          "when": "false"
        }
      ],
      "editor/context": [
        {
          "command": "codeReview.addComment",
          "group": "navigation@19",
          "when": "resourceScheme == file"
        }
      ],
      "comments/commentThread/context": [
        {
          "command": "codeReview.createComment",
          "group": "inline",
          "when": "commentController == local-review && commentThreadIsEmpty"
        }
      ],
      "comments/commentThread/title": [
        {
          "command": "codeReview.resolveItem",
          "group": "navigation@1",
          "when": "commentController == local-review && (commentThread == reviewOpen || commentThread == reviewStale)"
        },
        {
          "command": "codeReview.reopenItem",
          "group": "navigation@1",
          "when": "commentController == local-review && commentThread == reviewResolved"
        },
        {
          "command": "codeReview.dismissItem",
          "group": "navigation@2",
          "when": "commentController == local-review && (commentThread == reviewOpen || commentThread == reviewStale || commentThread == reviewResolved)"
        },
        {
          "command": "codeReview.deleteItem",
          "group": "navigation@3",
          "when": "commentController == local-review && (commentThread == draft || commentThread == reviewOpen || commentThread == reviewStale || commentThread == reviewResolved)"
        }
      ],
      "comments/comment/title": [
        {
          "command": "codeReview.editComment",
          "group": "inline@1",
          "when": "commentController == local-review && comment == reviewComment"
        }
      ],
      "comments/comment/context": [
        {
          "command": "codeReview.saveComment",
          "group": "inline@1",
          "when": "commentController == local-review && comment == reviewCommentEditing"
        },
        {
          "command": "codeReview.cancelComment",
          "group": "inline@2",
          "when": "commentController == local-review && comment == reviewCommentEditing"
        }
      ],
      "view/item/context": [
        {
          "command": "codeReview.openItem",
          "group": "inline@1",
          "when": "view == codeReviewExplorer && viewItem =~ /reviewItem/"
        },
        {
          "command": "codeReview.resolveItem",
          "group": "inline@2",
          "when": "view == codeReviewExplorer && (viewItem == reviewItem.open || viewItem == reviewItem.stale)"
        },
        {
          "command": "codeReview.reopenItem",
          "group": "inline@3",
          "when": "view == codeReviewExplorer && (viewItem == reviewItem.resolved || viewItem == reviewItem.dismissed)"
        },
        {
          "command": "codeReview.dismissItem",
          "group": "review@1",
          "when": "view == codeReviewExplorer && viewItem =~ /reviewItem/ && viewItem != reviewItem.dismissed"
        },
        {
          "command": "codeReview.copyItem",
          "group": "review@3",
          "when": "view == codeReviewExplorer && viewItem =~ /reviewItem/"
        },
        {
          "command": "codeReview.deleteItem",
          "group": "review@99",
          "when": "view == codeReviewExplorer && viewItem =~ /reviewItem/"
        },
        {
          "command": "codeReview.resolveGroup",
          "group": "inline@1",
          "when": "view == codeReviewExplorer && viewItem == reviewGroup.nonempty"
        },
        {
          "command": "codeReview.deleteGroup",
          "group": "inline@2",
          "when": "view == codeReviewExplorer && (viewItem == reviewGroup.nonempty || viewItem == reviewGroup.empty)"
        }
      ],
      "view/title": [
        {
          "command": "codeReview.startSession",
          "group": "navigation@0",
          "when": "view == codeReviewExplorer"
        },
        {
          "command": "codeReview.exportMarkdown",
          "group": "navigation@1",
          "when": "view == codeReviewExplorer"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "codeReview",
          "title": "Local Review",
          "icon": "resources/vscode-local-review.svg"
        }
      ]
    },
    "views": {
      "codeReview": [
        {
          "id": "codeReviewExplorer",
          "name": "Local Review"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "pnpm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "tsc --noEmit -p ./",
    "test": "pnpm run compile && node --test \"dist/test/*.test.js\"",
    "test:integration": "pnpm run compile && node ./dist/test/runIntegration.js",
    "release:prepare": "pnpm run compile && node ./dist/scripts/release.js prepare",
    "package:list": "vsce ls --tree",
    "package:vsix": "vsce package"
  },
  "devDependencies": {
    "@types/node": "22.14.0",
    "@types/vscode": "1.100.0",
    "@vscode/test-electron": "2.5.2",
    "@vscode/vsce": "^3.7.1",
    "ovsx": "^0.10.10",
    "typescript": "5.9.3"
  }
}
